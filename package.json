{
  "name": "eurus",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --runInBand --coverage",
    "test:all": "npm run lint && npm run test:ci && npm run smoke && npm run build",
    "test:all:fast": "npm run test:ci && npm run smoke && npm run build",
    "smoke": "playwright test tests/smoke --project=chromium",
    "smoke:headed": "playwright test tests/smoke --project=chromium --headed",
    "smoke:report": "playwright show-report",
    "backup:dynamo": "node scripts/backupDynamoData.js",
