{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",

    "inventory": {
      ".indexOn": ["sku", "barcode", "productName", "category", "collection", "brand", "brandId", "size", "status", "price", "wholesalePrice", "mrp", "costPrice", "stock", "gstRate", "hsnCode", "unit", "createdAt", "updatedAt", "createdBy"]
    },

    "users": {
      ".indexOn": ["role", "email", "name", "uid"]
    },

    "activities": {
      ".indexOn": ["timestamp", "type", "action", "userId", "userRole"]
    },

    "dispatches": {
      ".indexOn": ["status", "createdAt", "updatedAt", "partyName", "partyId", "transporterName", "transporterId", "dispatchType", "platform", "paymentStatus", "trackingId", "awb", "courierPartner", "dispatchDate"]
    },

    "tasks": {
      ".indexOn": ["assignedTo", "status", "priority", "createdAt", "createdBy", "expiresAt", "completedAt", "assignedToRole"]
    },

    "partyRates": {
      ".indexOn": ["partyName", "updatedAt"]
    },

    "categories": {
      ".indexOn": ["name", "createdAt", "createdBy"]
    },

    "collections": {
      ".indexOn": ["name", "collectionCode", "createdAt"]
    },

    "itemGroups": {
      ".indexOn": ["name", "createdAt"]
    },

    "brands": {
      ".indexOn": ["name", "createdAt"]
    },

    "parties": {
      ".indexOn": ["name", "phone", "gstin", "createdAt"]
    },

    "transporters": {
      ".indexOn": ["name", "phone", "createdAt"]
    }
  }
}
